<div class="container">
  <h1>Games#new</h1>
  <p>Find me in app/views/games/new.html.erb</p>
  <ul class="letters">
  <% @letters.each do |letter| %>
    <li><%= letter %></li>
  <% end %>
  </ul>
  <form action="/score" method="POST" data-turbo="false">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    <%= hidden_field_tag :letters, @letters %>
    <div class="input-group">
      <input type="text" name="response" class="form-control">
      <input type="submit" value="Play" class="btn btn-primary">
    </div>
  </form>
</div>
